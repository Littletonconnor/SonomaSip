    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "3.8.0",
    "shadcn": "^4.1.2",
